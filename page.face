<meta name="description" content="Twelve Scents offers pure frankincense, essential oils, an essential oil starter kit, aromatic incense, room sprays, holders and supplies for the nature-loving, earthy and spiritually minded.">
<meta name="keywords" content="pure frankincense, essential oil starter kit, essential oil, incense, holders, oil holders, room sprays, aromatic incense">
<meta property="og:title" content="Twelve Scents | Pure Frankincense, Essential Oils &amp; Incense">
<meta property="og:description" content="Aromatic incense, pure frankincense, essential oils, room sprays and supplies for earthy, spiritual living.">
<meta property="og:type" content="website">
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
*{box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{margin:0;font-family:'Manrope',system-ui,sans-serif;color:#3a342c;background:#F4EFE7;-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility;}
img{display:block;max-width:100%;}
button{font-family:inherit;}
::selection{background:#B5663C;color:#FBF8F3;}
@keyframes twfade{from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:none;}}
@media(max-width:860px){
 .tw-desktop-nav{display:none!important;}
 .tw-menu-btn{display:inline-flex!important;}
 .tw-2col{grid-template-columns:1fr!important;}
 .tw-hide-sm{display:none!important;}
 .tw-pad-sm{padding-top:64px!important;padding-bottom:64px!important;}
}
</style>
</helmet>



<div style="min-height:100vh;display:flex;flex-direction:column;">

  <header style="position:sticky;top:0;z-index:60;background:rgba(244,239,231,0.88);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border-bottom:1px solid #E4DCCE;">
    <sc-if value="{{ showBar }}" hint-placeholder-val="{{ true }}">
      <div style="background:#3C4A3E;color:#EDE7DA;text-align:center;font-size:12.5px;letter-spacing:0.04em;padding:9px 16px;font-weight:500;">{{ announcementText }}</div>
    </sc-if>
    <div style="max-width:1200px;margin:0 auto;padding:16px 24px;display:flex;align-items:center;justify-content:space-between;gap:20px;">
      <button onclick="{{ goHome }}" aria-label="Twelve Scents home" style="display:flex;align-items:center;gap:11px;background:none;border:none;padding:0;cursor:pointer;">
        <span style="width:34px;height:34px;border-radius:50%;background:#B5663C;display:flex;align-items:center;justify-content:center;color:#FBF8F3;font-family:'Cormorant Garamond',serif;font-weight:700;font-size:18px;flex:none;">12</span>
        <span style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:25px;letter-spacing:0.01em;color:#26221C;line-height:1;">Twelve&nbsp;Scents</span>
      </button>
      <nav class="tw-desktop-nav" aria-label="Primary" style="display:flex;align-items:center;gap:34px;">
        <sc-for list="{{ navItems }}" as="item" hint-placeholder-count="5">
          <button onclick="{{ item.onClick }}" style="position:relative;background:none;border:none;cursor:pointer;font-size:14.5px;font-weight:600;letter-spacing:0.01em;color:#4a4338;padding:6px 0;">
            {{ item.label }}
            <sc-if value="{{ item.active }}" hint-placeholder-val="{{ false }}">
              <span style="position:absolute;left:0;right:0;bottom:-3px;height:2px;background:#B5663C;border-radius:2px;"></span>
            </sc-if>
          </button>
        </sc-for>
      </nav>
      <div style="display:flex;align-items:center;gap:12px;">
        <button class="tw-desktop-nav" onclick="{{ goContact }}" style="display:inline-flex;align-items:center;gap:8px;background:#B5663C;color:#FBF8F3;border:none;padding:12px 24px;border-radius:999px;font-weight:600;font-size:14px;letter-spacing:0.02em;cursor:pointer;">Get in touch</button>
        <button class="tw-menu-btn" onclick="{{ toggleMobile }}" aria-label="Toggle menu" style="display:none;align-items:center;justify-content:center;width:44px;height:44px;border-radius:12px;background:#FBF8F3;border:1px solid #E4DCCE;cursor:pointer;flex-direction:column;gap:5px;">
          <span style="width:18px;height:2px;background:#26221C;border-radius:2px;"></span>
          <span style="width:18px;height:2px;background:#26221C;border-radius:2px;"></span>
          <span style="width:18px;height:2px;background:#26221C;border-radius:2px;"></span>
        </button>
      </div>
    </div>
    <sc-if value="{{ mobileOpen }}" hint-placeholder-val="{{ false }}">
      <nav aria-label="Mobile" style="border-top:1px solid #E4DCCE;background:#F4EFE7;padding:10px 24px 22px;display:flex;flex-direction:column;gap:2px;">
        <sc-for list="{{ navItems }}" as="item" hint-placeholder-count="5">
          <button onclick="{{ item.onClick }}" style="text-align:left;background:none;border:none;border-bottom:1px solid #EAE3D6;cursor:pointer;font-size:17px;font-weight:600;color:#26221C;padding:15px 4px;">{{ item.label }}</button>
        </sc-for>
        <button onclick="{{ goContact }}" style="margin-top:14px;background:#B5663C;color:#FBF8F3;border:none;padding:15px;border-radius:999px;font-weight:600;font-size:15px;cursor:pointer;">Get in touch</button>
      </nav>
    </sc-if>
  </header>

  <main style="flex:1;">

  <!-- ===================== HOME ===================== -->
  <sc-if value="{{ isHome }}" hint-placeholder-val="{{ true }}">
  <div>
    <!-- Hero -->
    <section style="position:relative;overflow:hidden;background:linear-gradient(135deg,#2c2b26,#3C4A3E);">
      <img src="data:image/jpeg;base64," alt="Aromatic incense burning with rising smoke in a calm, earthy setting" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.5;">
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(20,19,16,0.82) 0%,rgba(20,19,16,0.45) 55%,rgba(20,19,16,0.2) 100%);"></div>
      <div style="position:relative;max-width:1200px;margin:0 auto;padding:120px 24px 128px;">
        <div style="max-width:660px;">
          <p style="text-transform:uppercase;letter-spacing:0.2em;font-size:12.5px;font-weight:600;color:#E0A878;margin:0 0 22px;">Aromatics for earthy, spiritual living</p>
          <h1 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(46px,7vw,80px);line-height:1.02;color:#FBF8F3;margin:0 0 24px;letter-spacing:-0.01em;">Pure frankincense, essential oils &amp; incense — crafted for the senses</h1>
          <p style="font-size:18px;line-height:1.7;color:#E7E1D6;margin:0 0 36px;max-width:540px;">Hand-selected aromatic incense, pure essential oils, room sprays, holders and supplies. Small-batch, naturally sourced, and made to ground your space.</p>
          <div style="display:flex;flex-wrap:wrap;gap:14px;">
            <button onclick="{{ goListings }}" style="display:inline-flex;align-items:center;gap:9px;background:#B5663C;color:#FBF8F3;border:none;padding:16px 32px;border-radius:999px;font-weight:600;font-size:15px;letter-spacing:0.02em;cursor:pointer;">Shop the collection →</button>
            <button onclick="{{ goServices }}" style="display:inline-flex;align-items:center;gap:9px;background:rgba(251,248,243,0.08);color:#FBF8F3;border:1.5px solid rgba(251,248,243,0.45);padding:16px 32px;border-radius:999px;font-weight:600;font-size:15px;letter-spacing:0.02em;cursor:pointer;backdrop-filter:blur(4px);">What we offer</button>
          </div>
        </div>
      </div>
    </section>

    <!-- Value props -->
    <section style="max-width:1200px;margin:0 auto;padding:86px 24px;">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:28px;">
        <sc-for list="{{ valueProps }}" as="vp" hint-placeholder-count="3">
          <div style="background:#FBF8F3;border:1px solid #EAE3D6;border-radius:18px;padding:34px 30px;">
            <div style="width:44px;height:44px;border-radius:12px;background:#F0E4D4;display:flex;align-items:center;justify-content:center;font-size:21px;margin-bottom:20px;">{{ vp.icon }}</div>
            <h3 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:25px;color:#26221C;margin:0 0 10px;">{{ vp.title }}</h3>
            <p style="font-size:15px;line-height:1.65;color:#6a6255;margin:0;">{{ vp.body }}</p>
          </div>
        </sc-for>
      </div>
    </section>

    <!-- Categories / featured -->
    <section style="background:#EDE6D8;padding:90px 0;">
      <div style="max-width:1200px;margin:0 auto;padding:0 24px;">
        <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:24px;flex-wrap:wrap;margin-bottom:46px;">
          <div style="max-width:540px;">
            <p style="text-transform:uppercase;letter-spacing:0.18em;font-size:12px;font-weight:600;color:#B5663C;margin:0 0 14px;">Explore by ritual</p>
            <h2 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(34px,4.6vw,50px);line-height:1.05;color:#26221C;margin:0;">Everything for a grounded, fragrant space</h2>
          </div>
          <button onclick="{{ goListings }}" style="background:none;border:none;cursor:pointer;font-weight:600;font-size:15px;color:#B5663C;white-space:nowrap;">View all listings →</button>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:22px;">
          <sc-for list="{{ categories }}" as="cat" hint-placeholder-count="4">
            <button onclick="{{ cat.onClick }}" style="text-align:left;background:#FBF8F3;border:1px solid #E2DACB;border-radius:18px;overflow:hidden;cursor:pointer;padding:0;display:flex;flex-direction:column;">
              <div role="img" aria-label="{{ cat.alt }}" style="height:190px;background-color:#bcae93;background-image:url('{{ cat.img }}');background-size:cover;background-position:center;"></div>
              <div style="padding:20px 22px 24px;">
                <h3 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:23px;color:#26221C;margin:0 0 6px;">{{ cat.name }}</h3>
                <p style="font-size:14px;color:#6a6255;margin:0;line-height:1.55;">{{ cat.blurb }}</p>
              </div>
            </button>
          </sc-for>
        </div>
      </div>
    </section>

    <!-- Story strip -->
    <section style="max-width:1200px;margin:0 auto;padding:96px 24px;">
      <div class="tw-2col" style="display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;">
        <div style="position:relative;border-radius:22px;overflow:hidden;height:440px;background:linear-gradient(135deg,#b9a98c,#8a9a82);">
          <img src="data:image/jpeg;base64," alt="Hands holding bundled herbs and essential oil bottles in natural light" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;">
        </div>
        <div>
          <p style="text-transform:uppercase;letter-spacing:0.18em;font-size:12px;font-weight:600;color:#B5663C;margin:0 0 16px;">Our promise</p>
          <h2 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(32px,4.4vw,48px);line-height:1.08;color:#26221C;margin:0 0 22px;">Naturally sourced. Small batch. Made with intention.</h2>
          <p style="font-size:16.5px;line-height:1.75;color:#5C5246;margin:0 0 18px;">Every scent we carry is chosen for purity and provenance — from pure frankincense resin to single-origin essential oils. No synthetic fillers, no shortcuts.</p>
          <p style="font-size:16.5px;line-height:1.75;color:#5C5246;margin:0 0 30px;">We believe fragrance is a daily ritual. Our holders, supplies and starter kits make it easy to build one that feels like yours.</p>
          <button onclick="{{ goAbout }}" style="background:none;border:1.5px solid #26221C;color:#26221C;padding:14px 28px;border-radius:999px;font-weight:600;font-size:15px;cursor:pointer;">Read our story</button>
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section style="background:#3C4A3E;padding:92px 0;">
      <div style="max-width:1200px;margin:0 auto;padding:0 24px;">
        <p style="text-transform:uppercase;letter-spacing:0.18em;font-size:12px;font-weight:600;color:#C7B08F;margin:0 0 14px;text-align:center;">Loved by our community</p>
        <h2 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(32px,4.4vw,48px);color:#FBF8F3;margin:0 0 50px;text-align:center;">Scents people come back for</h2>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;">
          <sc-for list="{{ testimonials }}" as="t" hint-placeholder-count="3">
            <div style="background:rgba(251,248,243,0.06);border:1px solid rgba(251,248,243,0.14);border-radius:18px;padding:32px 30px;">
              <p style="font-size:18px;color:#D4A05a;letter-spacing:2px;margin:0 0 16px;">★★★★★</p>
              <p style="font-family:'Cormorant Garamond',serif;font-size:22px;line-height:1.45;color:#F1ECE1;margin:0 0 22px;">“{{ t.quote }}”</p>
              <p style="font-size:14px;font-weight:600;color:#C7B08F;margin:0;">{{ t.name }}</p>
            </div>
          </sc-for>
        </div>
      </div>
    </section>

    <!-- CTA band -->
    <section style="position:relative;overflow:hidden;">
      <img src="data:image/jpeg;base64," alt="Calm spa setting with stones, plants and soft natural light" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;">
      <div style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(38,34,28,0.78),rgba(38,34,28,0.85));"></div>
      <div style="position:relative;max-width:760px;margin:0 auto;padding:96px 24px;text-align:center;">
        <h2 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(34px,5vw,56px);color:#FBF8F3;margin:0 0 18px;line-height:1.05;">Begin your ritual today</h2>
        <p style="font-size:17px;line-height:1.7;color:#E7E1D6;margin:0 0 32px;">Not sure where to start? Our essential oil starter kit is the easiest way in — or reach out and we'll help you choose.</p>
        <div style="display:flex;flex-wrap:wrap;gap:14px;justify-content:center;">
          <button onclick="{{ goListings }}" style="background:#B5663C;color:#FBF8F3;border:none;padding:16px 32px;border-radius:999px;font-weight:600;font-size:15px;cursor:pointer;">Shop now</button>
          <button onclick="{{ goContact }}" style="background:#FBF8F3;color:#26221C;border:none;padding:16px 32px;border-radius:999px;font-weight:600;font-size:15px;cursor:pointer;">Contact us</button>
        </div>
      </div>
    </section>
  </div>
  </sc-if>

  <!-- ===================== ABOUT ===================== -->
  <sc-if value="{{ isAbout }}" hint-placeholder-val="{{ false }}">
  <div>
    <section style="background:#EDE6D8;padding:84px 0 76px;">
      <div style="max-width:840px;margin:0 auto;padding:0 24px;text-align:center;">
        <p style="text-transform:uppercase;letter-spacing:0.2em;font-size:12.5px;font-weight:600;color:#B5663C;margin:0 0 18px;">Our story</p>
        <h1 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(40px,6vw,68px);line-height:1.04;color:#26221C;margin:0 0 22px;">Scent as a daily ritual</h1>
        <p style="font-size:18px;line-height:1.75;color:#5C5246;margin:0;">Twelve Scents began with a simple belief: the air around us shapes how we feel, think and rest. We bring you pure, naturally sourced aromatics to make that intention part of everyday life.</p>
      </div>
    </section>

    <section style="max-width:1200px;margin:0 auto;padding:90px 24px;">
      <div class="tw-2col" style="display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;">
        <div style="position:relative;border-radius:22px;overflow:hidden;height:480px;background:linear-gradient(135deg,#b9a98c,#8a9a82);">
          <img src="data:image/jpeg;base64," alt="Essential oil bottles and dried botanicals arranged on a wooden surface" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;">
        </div>
        <div>
          <h2 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(30px,4vw,44px);line-height:1.1;color:#26221C;margin:0 0 22px;">Rooted in nature, guided by purity</h2>
          <p style="font-size:16.5px;line-height:1.75;color:#5C5246;margin:0 0 18px;">We source pure frankincense, single-origin essential oils and aromatic incense from growers and makers who share our standards. Everything is small-batch and free of synthetic fillers.</p>
          <p style="font-size:16.5px;line-height:1.75;color:#5C5246;margin:0 0 18px;">For the nature-loving, earthy and spiritually minded, scent is more than fragrance — it's grounding, presence and care. That's the experience we package into every bottle, bundle and spray.</p>
          <p style="font-size:16.5px;line-height:1.75;color:#5C5246;margin:0;">From holders and oil holders to complete starter kits, we make it easy to build a ritual that's unmistakably yours.</p>
        </div>
      </div>
    </section>

    <section style="background:#FBF8F3;border-top:1px solid #EAE3D6;border-bottom:1px solid #EAE3D6;padding:78px 0;">
      <div style="max-width:1200px;margin:0 auto;padding:0 24px;">
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:28px;">
          <sc-for list="{{ values }}" as="v" hint-placeholder-count="4">
            <div>
              <div style="width:46px;height:46px;border-radius:12px;background:#F0E4D4;display:flex;align-items:center;justify-content:center;font-size:22px;margin-bottom:18px;">{{ v.icon }}</div>
              <h3 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:23px;color:#26221C;margin:0 0 8px;">{{ v.title }}</h3>
              <p style="font-size:14.5px;line-height:1.65;color:#6a6255;margin:0;">{{ v.body }}</p>
            </div>
          </sc-for>
        </div>
      </div>
    </section>

    <section style="max-width:760px;margin:0 auto;padding:90px 24px;text-align:center;">
      <h2 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(30px,4.4vw,46px);color:#26221C;margin:0 0 18px;">Let's find your scent</h2>
      <p style="font-size:16.5px;line-height:1.7;color:#5C5246;margin:0 0 30px;">Browse the collection or get in touch — we love helping people start their ritual.</p>
      <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;">
        <button onclick="{{ goListings }}" style="background:#B5663C;color:#FBF8F3;border:none;padding:15px 30px;border-radius:999px;font-weight:600;font-size:15px;cursor:pointer;">Browse listings</button>
        <button onclick="{{ goContact }}" style="background:none;border:1.5px solid #26221C;color:#26221C;padding:15px 30px;border-radius:999px;font-weight:600;font-size:15px;cursor:pointer;">Contact us</button>
      </div>
    </section>
  </div>
  </sc-if>

  <!-- ===================== SERVICES ===================== -->
  <sc-if value="{{ isServices }}" hint-placeholder-val="{{ false }}">
  <div>
    <section style="background:#3C4A3E;padding:84px 0 78px;">
      <div style="max-width:840px;margin:0 auto;padding:0 24px;text-align:center;">
        <p style="text-transform:uppercase;letter-spacing:0.2em;font-size:12.5px;font-weight:600;color:#C7B08F;margin:0 0 18px;">What we offer</p>
        <h1 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(40px,6vw,66px);line-height:1.04;color:#FBF8F3;margin:0 0 20px;">Aromatics, supplies &amp; everything between</h1>
        <p style="font-size:18px;line-height:1.7;color:#E2DCCF;margin:0;">From pure frankincense to a complete essential oil starter kit — explore the full range of what Twelve Scents creates and curates.</p>
      </div>
    </section>

    <section style="max-width:1200px;margin:0 auto;padding:84px 24px;">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:26px;">
        <sc-for list="{{ services }}" as="s" hint-placeholder-count="5">
          <div style="background:#FBF8F3;border:1px solid #EAE3D6;border-radius:20px;overflow:hidden;display:flex;flex-direction:column;">
            <div role="img" aria-label="{{ s.alt }}" style="height:200px;background-color:#bcae93;background-image:url('{{ s.img }}');background-size:cover;background-position:center;"></div>
            <div style="padding:28px 28px 30px;display:flex;flex-direction:column;flex:1;">
              <h3 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:26px;color:#26221C;margin:0 0 12px;">{{ s.title }}</h3>
              <p style="font-size:15px;line-height:1.68;color:#6a6255;margin:0 0 20px;flex:1;">{{ s.body }}</p>
              <button onclick="{{ s.onClick }}" style="align-self:flex-start;background:none;border:none;cursor:pointer;font-weight:600;font-size:14.5px;color:#B5663C;padding:0;">Shop {{ s.title }} →</button>
            </div>
          </div>
        </sc-for>
      </div>
    </section>

    <section style="background:#EDE6D8;padding:84px 0;">
      <div style="max-width:760px;margin:0 auto;padding:0 24px;text-align:center;">
        <h2 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(30px,4.4vw,46px);color:#26221C;margin:0 0 16px;">Need help choosing?</h2>
        <p style="font-size:16.5px;line-height:1.7;color:#5C5246;margin:0 0 28px;">Tell us about your space and what you're after — we'll put together the right scents and supplies for you.</p>
        <button onclick="{{ goContact }}" style="background:#B5663C;color:#FBF8F3;border:none;padding:16px 32px;border-radius:999px;font-weight:600;font-size:15px;cursor:pointer;">Get a recommendation</button>
      </div>
    </section>
  </div>
  </sc-if>

  <!-- ===================== LISTINGS ===================== -->
  <sc-if value="{{ isListings }}" hint-placeholder-val="{{ false }}">
  <div>
    <section style="background:#EDE6D8;padding:74px 0 60px;">
      <div style="max-width:1200px;margin:0 auto;padding:0 24px;text-align:center;">
        <p style="text-transform:uppercase;letter-spacing:0.2em;font-size:12.5px;font-weight:600;color:#B5663C;margin:0 0 16px;">The collection</p>
        <h1 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(40px,6vw,64px);line-height:1.04;color:#26221C;margin:0 0 14px;">Listings</h1>
        <p style="font-size:17px;line-height:1.7;color:#5C5246;margin:0 auto;max-width:560px;">Pure frankincense, essential oils, incense, room sprays, holders and supplies — all small-batch and naturally sourced.</p>
      </div>
    </section>

    <section style="max-width:1200px;margin:0 auto;padding:40px 24px 90px;">
      <div style="display:flex;flex-wrap:wrap;gap:10px;justify-content:center;margin-bottom:44px;">
        <sc-for list="{{ filterBtns }}" as="f" hint-placeholder-count="6">
          <button onclick="{{ f.onClick }}" style="{{ f.style }}">{{ f.label }}</button>
        </sc-for>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:26px;">
        <sc-for list="{{ filteredProducts }}" as="p" hint-placeholder-count="9">
          <div style="background:#FBF8F3;border:1px solid #EAE3D6;border-radius:18px;overflow:hidden;display:flex;flex-direction:column;">
            <div role="img" aria-label="{{ p.alt }}" style="position:relative;height:230px;background-color:#bcae93;background-image:url('{{ p.img }}');background-size:cover;background-position:center;">
              <span style="position:absolute;top:14px;left:14px;background:rgba(38,34,28,0.78);color:#F1ECE1;font-size:11px;font-weight:600;letter-spacing:0.04em;padding:6px 11px;border-radius:999px;">{{ p.category }}</span>
            </div>
            <div style="padding:20px 22px 24px;display:flex;flex-direction:column;flex:1;">
              <h3 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:22px;color:#26221C;margin:0 0 6px;line-height:1.2;">{{ p.name }}</h3>
              <p style="font-size:13.5px;line-height:1.55;color:#6a6255;margin:0 0 18px;flex:1;">{{ p.desc }}</p>
              <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;">
                <span style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:22px;color:#26221C;">{{ p.price }}</span>
                <button onclick="{{ goContact }}" style="background:#26221C;color:#FBF8F3;border:none;padding:11px 18px;border-radius:999px;font-weight:600;font-size:13px;cursor:pointer;white-space:nowrap;">Inquire</button>
              </div>
            </div>
          </div>
        </sc-for>
      </div>
    </section>
  </div>
  </sc-if>

  <!-- ===================== CONTACT ===================== -->
  <sc-if value="{{ isContact }}" hint-placeholder-val="{{ false }}">
  <div>
    <section style="background:#EDE6D8;padding:74px 0 60px;">
      <div style="max-width:840px;margin:0 auto;padding:0 24px;text-align:center;">
        <p style="text-transform:uppercase;letter-spacing:0.2em;font-size:12.5px;font-weight:600;color:#B5663C;margin:0 0 16px;">Say hello</p>
        <h1 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:clamp(40px,6vw,64px);line-height:1.04;color:#26221C;margin:0 0 14px;">Contact us</h1>
        <p style="font-size:17px;line-height:1.7;color:#5C5246;margin:0 auto;max-width:540px;">Questions, custom orders or wholesale — we'd love to hear from you. We typically reply within one business day.</p>
      </div>
    </section>

    <section style="max-width:1100px;margin:0 auto;padding:80px 24px 96px;">
      <div class="tw-2col" style="display:grid;grid-template-columns:1.2fr 0.9fr;gap:54px;align-items:start;">
        <div style="background:#FBF8F3;border:1px solid #EAE3D6;border-radius:22px;padding:38px 36px;">
          <sc-if value="{{ sent }}" hint-placeholder-val="{{ false }}">
            <div style="text-align:center;padding:30px 10px;">
              <div style="width:56px;height:56px;border-radius:50%;background:#E7EBDF;display:flex;align-items:center;justify-content:center;font-size:26px;margin:0 auto 18px;">✦</div>
              <h3 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:28px;color:#26221C;margin:0 0 10px;">Thank you</h3>
              <p style="font-size:15.5px;line-height:1.6;color:#6a6255;margin:0;">Your message is on its way. We'll be in touch soon.</p>
            </div>
          </sc-if>
          <sc-if value="{{ notSent }}" hint-placeholder-val="{{ true }}">
            <form onsubmit="{{ submitContact }}">
              <h2 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:28px;color:#26221C;margin:0 0 22px;">Send a message</h2>
              <label style="display:block;font-size:13px;font-weight:600;color:#5C5246;margin-bottom:7px;">Name</label>
              <input type="text" required="" placeholder="Your name" style="width:100%;padding:13px 15px;border:1px solid #DED5C5;border-radius:11px;background:#FCFAF6;font-size:15px;color:#26221C;margin-bottom:18px;">
              <label style="display:block;font-size:13px;font-weight:600;color:#5C5246;margin-bottom:7px;">Email</label>
              <input type="email" required="" placeholder="you@email.com" style="width:100%;padding:13px 15px;border:1px solid #DED5C5;border-radius:11px;background:#FCFAF6;font-size:15px;color:#26221C;margin-bottom:18px;">
              <label style="display:block;font-size:13px;font-weight:600;color:#5C5246;margin-bottom:7px;">Message</label>
              <textarea required="" rows="5" placeholder="Tell us what you're looking for…" style="width:100%;padding:13px 15px;border:1px solid #DED5C5;border-radius:11px;background:#FCFAF6;font-size:15px;color:#26221C;margin-bottom:22px;resize:vertical;font-family:inherit;"></textarea>
              <button type="submit" style="width:100%;background:#B5663C;color:#FBF8F3;border:none;padding:15px;border-radius:999px;font-weight:600;font-size:15px;cursor:pointer;">Send message</button>
            </form>
          </sc-if>
        </div>
        <div>
          <div style="margin-bottom:30px;">
            <h3 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:21px;color:#26221C;margin:0 0 6px;">Email</h3>
            <a href="mailto:{{ contactEmail }}" style="font-size:15.5px;color:#B5663C;text-decoration:none;">{{ contactEmail }}</a>
          </div>
          <div style="margin-bottom:30px;">
            <h3 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:21px;color:#26221C;margin:0 0 6px;">Phone</h3>
            <a href="tel:{{ contactPhoneHref }}" style="font-size:15.5px;color:#B5663C;text-decoration:none;">{{ contactPhone }}</a>
          </div>
          <div style="margin-bottom:30px;">
            <h3 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:21px;color:#26221C;margin:0 0 6px;">Hours</h3>
            <p style="font-size:15px;color:#5C5246;line-height:1.6;margin:0;">Mon–Fri · 9am – 5pm<br>Sat · 10am – 3pm</p>
          </div>
          <div>
            <h3 style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:21px;color:#26221C;margin:0 0 12px;">Follow</h3>
            <div style="display:flex;gap:10px;">
              <a href="{{ instagramUrl }}" target="_blank" rel="noopener" style="width:42px;height:42px;border-radius:11px;background:#FBF8F3;border:1px solid #EAE3D6;display:flex;align-items:center;justify-content:center;color:#26221C;text-decoration:none;font-size:13px;font-weight:600;">IG</a>
              <a href="{{ facebookUrl }}" target="_blank" rel="noopener" style="width:42px;height:42px;border-radius:11px;background:#FBF8F3;border:1px solid #EAE3D6;display:flex;align-items:center;justify-content:center;color:#26221C;text-decoration:none;font-size:13px;font-weight:600;">FB</a>
              <a href="{{ pinterestUrl }}" target="_blank" rel="noopener" style="width:42px;height:42px;border-radius:11px;background:#FBF8F3;border:1px solid #EAE3D6;display:flex;align-items:center;justify-content:center;color:#26221C;text-decoration:none;font-size:13px;font-weight:600;">PT</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
  </sc-if>

  </main>

  <!-- ===================== FOOTER ===================== -->
  <footer style="background:#26221C;color:#D9D2C6;">
    <div style="max-width:1200px;margin:0 auto;padding:70px 24px 40px;">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:40px;margin-bottom:50px;">
        <div style="max-width:300px;">
          <div style="display:flex;align-items:center;gap:11px;margin-bottom:18px;">
            <span style="width:34px;height:34px;border-radius:50%;background:#B5663C;display:flex;align-items:center;justify-content:center;color:#FBF8F3;font-family:'Cormorant Garamond',serif;font-weight:700;font-size:18px;">12</span>
            <span style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:24px;color:#FBF8F3;">Twelve Scents</span>
          </div>
          <p style="font-size:14.5px;line-height:1.65;color:#A89E8E;margin:0;">Pure frankincense, essential oils, aromatic incense, room sprays and supplies for earthy, spiritual living.</p>
        </div>
        <div>
          <h4 style="font-size:13px;text-transform:uppercase;letter-spacing:0.14em;color:#C7B08F;margin:0 0 18px;">Explore</h4>
          <div style="display:flex;flex-direction:column;gap:12px;align-items:flex-start;">
            <sc-for list="{{ navItems }}" as="item" hint-placeholder-count="5">
              <button onclick="{{ item.onClick }}" style="background:none;border:none;cursor:pointer;color:#D9D2C6;font-size:14.5px;padding:0;text-align:left;">{{ item.label }}</button>
            </sc-for>
          </div>
        </div>
        <div>
          <h4 style="font-size:13px;text-transform:uppercase;letter-spacing:0.14em;color:#C7B08F;margin:0 0 18px;">Contact</h4>
          <div style="display:flex;flex-direction:column;gap:12px;">
            <a href="mailto:{{ contactEmail }}" style="color:#D9D2C6;font-size:14.5px;text-decoration:none;">{{ contactEmail }}</a>
            <a href="tel:{{ contactPhoneHref }}" style="color:#D9D2C6;font-size:14.5px;text-decoration:none;">{{ contactPhone }}</a>
            <p style="color:#A89E8E;font-size:14px;line-height:1.55;margin:0;">Mon–Fri 9–5 · Sat 10–3</p>
          </div>
        </div>
        <div>
          <h4 style="font-size:13px;text-transform:uppercase;letter-spacing:0.14em;color:#C7B08F;margin:0 0 18px;">Follow</h4>
          <div style="display:flex;gap:10px;">
            <a href="{{ instagramUrl }}" target="_blank" rel="noopener" style="width:40px;height:40px;border-radius:10px;background:rgba(251,248,243,0.07);display:flex;align-items:center;justify-content:center;color:#F1ECE1;text-decoration:none;font-size:12.5px;font-weight:600;">IG</a>
            <a href="{{ facebookUrl }}" target="_blank" rel="noopener" style="width:40px;height:40px;border-radius:10px;background:rgba(251,248,243,0.07);display:flex;align-items:center;justify-content:center;color:#F1ECE1;text-decoration:none;font-size:12.5px;font-weight:600;">FB</a>
            <a href="{{ pinterestUrl }}" target="_blank" rel="noopener" style="width:40px;height:40px;border-radius:10px;background:rgba(251,248,243,0.07);display:flex;align-items:center;justify-content:center;color:#F1ECE1;text-decoration:none;font-size:12.5px;font-weight:600;">PT</a>
          </div>
        </div>
      </div>
      <div style="border-top:1px solid rgba(251,248,243,0.1);padding-top:26px;display:flex;flex-wrap:wrap;gap:10px;justify-content:space-between;align-items:center;">
        <p style="font-size:13px;color:#8f8676;margin:0;">© {{ year }} Twelve Scents. All rights reserved.</p>
        <p style="font-size:13px;color:#8f8676;margin:0;">Naturally sourced · Small batch · Made with intention</p>
      </div>
    </div>
  </footer>

</div>
</x-dc>
<script type="text/x-dc" data-dc-script="" data-props="{&quot;$preview&quot;:{&quot;width&quot;:1280,&quot;height&quot;:900},&quot;showAnnouncementBar&quot;:{&quot;editor&quot;:&quot;boolean&quot;,&quot;default&quot;:true,&quot;tsType&quot;:&quot;boolean&quot;},&quot;announcementText&quot;:{&quot;editor&quot;:&quot;text&quot;,&quot;default&quot;:&quot;Free shipping on orders over $75 · Naturally sourced, small-batch aromatics&quot;,&quot;tsType&quot;:&quot;string&quot;},&quot;contactEmail&quot;:{&quot;editor&quot;:&quot;text&quot;,&quot;default&quot;:&quot;salessupport@twelve12scents.com&quot;,&quot;tsType&quot;:&quot;string&quot;},&quot;contactPhone&quot;:{&quot;editor&quot;:&quot;text&quot;,&quot;default&quot;:&quot;(240) 259-7668&quot;,&quot;tsType&quot;:&quot;string&quot;},&quot;instagramUrl&quot;:{&quot;editor&quot;:&quot;text&quot;,&quot;default&quot;:&quot;https://instagram.com&quot;,&quot;tsType&quot;:&quot;string&quot;},&quot;facebookUrl&quot;:{&quot;editor&quot;:&quot;text&quot;,&quot;default&quot;:&quot;https://facebook.com/twelvescents&quot;,&quot;tsType&quot;:&quot;string&quot;},&quot;pinterestUrl&quot;:{&quot;editor&quot;:&quot;text&quot;,&quot;default&quot;:&quot;https://pinterest.com&quot;,&quot;tsType&quot;:&quot;string&quot;}}">
class Component extends DCLogic {
  state = { page: 'home', mobileOpen: false, filter: 'All', sent: false };

  nav(page) {
    this.setState({ page, mobileOpen: false, sent: false });
    try { window.scrollTo({ top: 0, left: 0, behavior: 'auto' }); } catch (e) { window.scrollTo(0, 0); }
  }

  componentDidMount() { this._titlePage = this.state.page; this.setTitle(); }
  componentDidUpdate() { if (this._titlePage !== this.state.page) { this._titlePage = this.state.page; this.setTitle(); } }
  setTitle() {
    const map = {
      home: 'Twelve Scents | Pure Frankincense, Essential Oils & Incense',
      about: 'About Twelve Scents | Our Story & Mission',
      services: 'Services | Incense, Oils, Room Sprays & Supplies',
      listings: 'Listings | Shop Incense, Oils, Holders & Supplies',
      contact: 'Contact Twelve Scents'
    };
    try { document.title = map[this.state.page] || map.home; } catch (e) {}
  }

  renderVals() {
    const page = this.state.page;
    const props = this.props || {};
    const U = 'auto=format&fit=crop&q=80';

    const navItems = ['home', 'about', 'services', 'listings', 'contact'].map(p => ({
      label: p.charAt(0).toUpperCase() + p.slice(1),
      active: page === p,
      onClick: () => this.nav(p)
    }));

    const valueProps = [
      { icon: '🌿', title: 'Naturally sourced', body: 'Pure frankincense, single-origin oils and resins chosen for provenance and purity — never synthetic.' },
      { icon: '✦', title: 'Small-batch craft', body: 'Made and curated in small batches so every scent stays fresh, potent and true to its source.' },
      { icon: '☾', title: 'Spiritually grounded', body: 'Aromatics, holders and supplies designed to turn everyday moments into a grounding ritual.' }
    ];

    const values = [
      { icon: '🌿', title: 'Purity first', body: 'No fillers, no synthetics — only clean, naturally sourced aromatics.' },
      { icon: '♻️', title: 'Mindful sourcing', body: 'We work with growers and makers who respect the land and their craft.' },
      { icon: '✦', title: 'Intentional', body: 'Every product is made to support ritual, rest and presence.' },
      { icon: '♡', title: 'Community', body: 'We grow with the earthy, spiritual community we serve.' }
    ];

    const categories = [
      { name: 'Aromatic Incense', blurb: 'Resins, sticks & bundles', img: 'https://images.unsplash.com/photo-1602173574767-37ac01994b2a?' + U + '&w=700', alt: 'Aromatic incense sticks with rising smoke', onClick: () => this.nav('listings') },
      { name: 'Essential Oils', blurb: 'Single-origin & blends', img: 'https://images.unsplash.com/photo-1608571423902-eed4a5ad8108?' + U + '&w=700', alt: 'Amber essential oil bottles with botanicals', onClick: () => this.nav('listings') },
      { name: 'Room Sprays', blurb: 'Refresh any space', img: 'https://images.unsplash.com/photo-1608248543803-ba4f8c70ae0b?' + U + '&w=700', alt: 'Natural room spray bottle on a wooden shelf', onClick: () => this.nav('listings') },
      { name: 'Holders & Supplies', blurb: 'Brass, ceramic & more', img: 'https://images.unsplash.com/photo-1604335399105-a0c585fd81a1?' + U + '&w=700', alt: 'Incense and oil holders made of brass and ceramic', onClick: () => this.nav('listings') }
    ];

    const services = [
      { title: 'Aromatic Incense', body: 'Hand-selected resins, sticks and smudge bundles — including pure frankincense and sacred sandalwood — for cleansing and calm.', img: 'https://images.unsplash.com/photo-1602173574767-37ac01994b2a?' + U + '&w=800', alt: 'Burning aromatic incense with curling smoke', onClick: () => this.nav('listings') },
      { title: 'Essential Oils', body: 'Single-origin and blended essential oils, pressed and distilled for purity. Perfect for diffusing, topical use and rituals.', img: 'https://images.unsplash.com/photo-1608571423902-eed4a5ad8108?' + U + '&w=800', alt: 'Collection of essential oil bottles with herbs', onClick: () => this.nav('listings') },
      { title: 'Room Sprays', body: 'Naturally scented room and linen sprays that refresh your space without synthetic fragrance or harsh chemicals.', img: 'https://images.unsplash.com/photo-1608248543803-ba4f8c70ae0b?' + U + '&w=800', alt: 'Natural room spray in an earthy setting', onClick: () => this.nav('listings') },
      { title: 'Holders & Supplies', body: 'Brass and ceramic incense holders, oil holders, diffuser dishes and the supplies that complete your setup.', img: 'https://images.unsplash.com/photo-1604335399105-a0c585fd81a1?' + U + '&w=800', alt: 'Incense holders and oil holders on display', onClick: () => this.nav('listings') },
      { title: 'Starter Kits', body: 'Our essential oil starter kit and curated bundles make it easy to begin — everything you need, thoughtfully paired.', img: 'https://images.unsplash.com/photo-1556760544-74068565f05c?' + U + '&w=800', alt: 'Essential oil starter kit with multiple bottles', onClick: () => this.nav('listings') }
    ];

    const testimonials = [
      { quote: 'The pure frankincense is unlike anything I\u2019ve found locally — rich, clean and grounding.', name: 'Maya R.' },
      { quote: 'My essential oil starter kit arrived beautifully packaged. I use it every single morning now.', name: 'Devon L.' },
      { quote: 'The room sprays make my whole home feel like a calm retreat. I\u2019m a customer for life.', name: 'Priya S.' }
    ];

    const products = [
      { name: 'Pure Frankincense Resin', price: '$18', category: 'Incense', desc: 'Premium Boswellia tears for a deep, sacred aroma.', img: 'https://images.unsplash.com/photo-1602173574767-37ac01994b2a?' + U + '&w=700', alt: 'Pure frankincense resin tears' },
      { name: 'Sacred Sandalwood Sticks', price: '$12', category: 'Incense', desc: 'Slow-burning hand-rolled sandalwood incense sticks.', img: 'https://images.unsplash.com/photo-1612817288484-6f916006741a?' + U + '&w=700', alt: 'Sandalwood incense sticks burning' },
      { name: 'White Sage & Palo Santo', price: '$16', category: 'Incense', desc: 'A cleansing bundle of ethically gathered botanicals.', img: 'https://images.unsplash.com/photo-1606744888344-493238951221?' + U + '&w=700', alt: 'White sage and palo santo smudge bundle' },
      { name: 'Lavender Essential Oil', price: '$14', category: 'Essential Oils', desc: 'Single-origin lavender for calm and restful sleep.', img: 'https://images.unsplash.com/photo-1608571423902-eed4a5ad8108?' + U + '&w=700', alt: 'Lavender essential oil bottle with sprigs' },
      { name: 'Essential Oil Starter Kit', price: '$48', category: 'Starter Kits', desc: 'Six everyday oils, thoughtfully paired to begin.', img: 'https://images.unsplash.com/photo-1556760544-74068565f05c?' + U + '&w=700', alt: 'Essential oil starter kit with six bottles' },
      { name: 'Eucalyptus & Mint Spray', price: '$20', category: 'Room Sprays', desc: 'A bright, clearing room and linen spray.', img: 'https://images.unsplash.com/photo-1608248543803-ba4f8c70ae0b?' + U + '&w=700', alt: 'Eucalyptus and mint room spray' },
      { name: 'Cedar & Amber Spray', price: '$20', category: 'Room Sprays', desc: 'Warm, woody notes to ground any room.', img: 'https://images.unsplash.com/photo-1610701596007-11502861dcfa?' + U + '&w=700', alt: 'Cedar and amber room spray bottle' },
      { name: 'Brass Incense Holder', price: '$24', category: 'Holders & Supplies', desc: 'Hand-finished brass holder for sticks and cones.', img: 'https://images.unsplash.com/photo-1604335399105-a0c585fd81a1?' + U + '&w=700', alt: 'Brass incense holder' },
      { name: 'Ceramic Oil Holder Dish', price: '$22', category: 'Holders & Supplies', desc: 'Minimal ceramic dish for oils and diffusing.', img: 'https://images.unsplash.com/photo-1612817288484-6f916006741a?' + U + '&w=700', alt: 'Ceramic oil holder dish' }
    ];

    const cats = ['All', 'Incense', 'Essential Oils', 'Room Sprays', 'Holders & Supplies', 'Starter Kits'];
    const filter = this.state.filter;
    const filterBtns = cats.map(c => {
      const on = c === filter;
      return {
        label: c,
        onClick: () => this.setState({ filter: c }),
        style: 'cursor:pointer;font-size:13.5px;font-weight:600;padding:10px 18px;border-radius:999px;letter-spacing:0.01em;' +
          (on ? 'background:#26221C;color:#FBF8F3;border:1px solid #26221C;' : 'background:#FBF8F3;color:#5C5246;border:1px solid #DED5C5;')
      };
    });
    const filteredProducts = filter === 'All' ? products : products.filter(p => p.category === filter);

    const phone = props.contactPhone || '(555) 012\u20113456';
    return {
      isHome: page === 'home', isAbout: page === 'about', isServices: page === 'services',
      isListings: page === 'listings', isContact: page === 'contact',
      navItems,
      goHome: () => this.nav('home'), goAbout: () => this.nav('about'),
      goServices: () => this.nav('services'), goListings: () => this.nav('listings'),
      goContact: () => this.nav('contact'),
      mobileOpen: this.state.mobileOpen,
      toggleMobile: () => this.setState(s => ({ mobileOpen: !s.mobileOpen })),
      valueProps, values, categories, services, testimonials,
      filterBtns, filteredProducts,
      imgError: (e) => { try { e.target.style.opacity = 0; } catch (er) {} },
      sent: this.state.sent, notSent: !this.state.sent,
      submitContact: (e) => { e.preventDefault(); this.setState({ sent: true }); },
      showBar: props.showAnnouncementBar !== false,
      announcementText: props.announcementText || 'Free shipping on orders over $50 · Naturally sourced, small-batch aromatics',
      contactEmail: props.contactEmail || 'hello@twelvescents.com',
      contactPhone: phone,
      contactPhoneHref: phone.replace(/[^0-9+]/g, ''),
      instagramUrl: props.instagramUrl || 'https://instagram.com',
      facebookUrl: props.facebookUrl || 'https://facebook.com',
      pinterestUrl: props.pinterestUrl || 'https://pinterest.com',
      year: new Date().getFullYear()
    };
  }
}
</script>
{% endraw %}
{% endblock %}
